# Server
NODE_ENV=development
PORT=3001

# PostgreSQL (single DB for both ltijs and app tables)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cetu_lms
DB_USER=cetu_user
DB_PASSWORD=changeme_strong_password

# Hosted PostgreSQL / Neon
# Use this instead of DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD in production.
# Neon connection strings must include sslmode=require.
# Example:
# DATABASE_URL=postgresql://user:password@ep-example.us-east-1.aws.neon.tech/cetu_lms?sslmode=require

# JWT (internal portal auth)
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')|xargs echo"
JWT_SECRET=replace_with_64_char_random_hex

# ltijs encryption key — must be EXACTLY 32 characters
# Generate with: node -e "require('crypto').randomBytes(16).toString('hex')|xargs echo"
LTI_KEY=replace_with_32_char_random_string

# CORS — frontend origin
FRONTEND_URL=http://localhost:5173

# Initial superadmin seed credentials
SEED_ADMIN_EMAIL=admin@cetu.mil
SEED_ADMIN_PASSWORD=ChangeMe!OnFirstLogin1

# Logging
LOG_LEVEL=debug
