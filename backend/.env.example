# Server
NODE_ENV=development
PORT=3001

# PostgreSQL (single DB for both ltijs and app tables)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cetu_lms
DB_USER=cetu_user
DB_PASSWORD=changeme_strong_password

# Hosted PostgreSQL / Neon
# Use this instead of DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD in production.
# Neon connection strings must include sslmode=require.
# Example:
# DATABASE_URL=postgresql://user:password@ep-example.us-east-1.aws.neon.tech/cetu_lms?sslmode=require

# JWT (internal portal auth)
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')|xargs echo"
JWT_SECRET=replace_with_64_char_random_hex

# ltijs encryption key — must be EXACTLY 32 characters
# Generate with: node -e "require('crypto').randomBytes(16).toString('hex')|xargs echo"
LTI_KEY=replace_with_32_char_random_string

# CORS — frontend origin
FRONTEND_URL=http://localhost:5173

# Initial superadmin seed credentials
SEED_ADMIN_EMAIL=admin@cetu.mil
SEED_ADMIN_PASSWORD=ChangeMe!OnFirstLogin1

# Cloudflare R2 — object storage for slide decks and scenario packages
# R2_ENDPOINT: the S3-compatible endpoint for your R2 account
# R2_PUBLIC_BASE_URL: the public CDN/domain in front of your R2 bucket (NO trailing slash)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace_with_r2_access_key
R2_SECRET_ACCESS_KEY=replace_with_r2_secret_key
R2_BUCKET=pact
R2_PUBLIC_BASE_URL=https://your-r2-public-domain.example.com

# R2 key prefixes (defaults shown; override only if your bucket layout differs)
# R2_SLIDES_PREFIX=pact/decks/
# R2_DECKS_PREFIX=scenarios/  # scenario packages and Drop N case-file source

# Stream Chat — https://getstream.io (App → Dashboard → API Keys)
# STREAM_API_SECRET must never be exposed to the frontend — server-side token minting only.
STREAM_API_KEY=replace_with_stream_api_key
STREAM_API_SECRET=replace_with_stream_api_secret
STREAM_CHAT_CHANNEL_TYPE=messaging

# Cloudflare Email Service — used for the forgot-password email.
# Needs a Cloudflare API token with "Email Sending: Edit" permission, and the
# PASSWORD_RESET_FROM_EMAIL domain must be onboarded to Email Sending first
# (Dashboard → Email Service → Email Sending → Onboard Domain, or
# `npx wrangler email sending enable yourdomain.com`).
CLOUDFLARE_EMAIL_API_TOKEN=replace_with_email_sending_scoped_token
PASSWORD_RESET_FROM_EMAIL=noreply@yourdomain.com

# Logging
LOG_LEVEL=debug
